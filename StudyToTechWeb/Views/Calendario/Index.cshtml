@using StudyToTechWeb.Models
@model List<CalendarioEstudos>

@{
    ViewData["Title"] = "Calendário de Estudos";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calendário</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Calendário de Estudos</h1>
            <a href="@Url.Action("Index", "Home")" class="back-link">← Voltar</a>
        </header>

        <form method="post" class="form-container" style="margin: 20px 0;">
            <h3>Adicionar Evento</h3>
            <div class="form-group">
                <label>Título</label>
                <input type="text" name="titulo" placeholder="Ex: Aula de Cálculo" required>
            </div>
            <div class="form-group">
                <label>Descrição</label>
                <textarea name="descricao" placeholder="Descrição do evento" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label>Data</label>
                <input type="datetime-local" name="data" required>
            </div>
            <button type="submit" class="btn-primary">Adicionar</button>
        </form>

        <div class="eventos-list">
            <h3>Eventos Agendados</h3>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var evento in Model)
                {
                    <div class="evento-card">
                        <h4>@evento.Titulo</h4>
                        <p>@evento.Descricao</p>
                        <small>📅 @evento.Data.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                }
            }
            else
            {
                <p>Nenhum evento agendado.</p>
            }
        </div>
    </div>

    <style>
        .form-container { max-width: 600px; margin: 0 auto; border: 1px solid #ddd; padding: 15px; border-radius: 8px; background-color: #f9f9f9; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
        .form-group input, .form-group textarea { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
        .btn-primary { padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; }
        .eventos-list { margin-top: 30px; max-width: 600px; margin-left: auto; margin-right: auto; }
        .evento-card { border: 1px solid #ddd; padding: 15px; margin: 10px 0; border-radius: 4px; background-color: #f0f0f0; }
        .evento-card h4 { margin: 0; }
        .evento-card p { margin: 5px 0; }
        .evento-card small { color: #666; }
        .back-link { cursor: pointer; }
    </style>
</body>
</html>
