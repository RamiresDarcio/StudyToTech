@{
    ViewData["Title"] = "Criar Tarefa";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Tarefa</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Criar Tarefa</h1>
        </header>

        <form method="post" class="form-container">
            @if (!string.IsNullOrEmpty(ViewBag.Erro))
            {
                <div style="color: red; margin-bottom: 10px;">
                    <strong>Erro:</strong> @ViewBag.Erro
                </div>
            }

            <div class="form-group">
                <label>Título</label>
                <input type="text" name="titulo" placeholder="Ex: Resolver lista de exercícios" required>
            </div>

            <div class="form-group">
                <label>Descrição</label>
                <textarea name="descricao" placeholder="Descrição da tarefa" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label>Disciplina</label>
                <input type="text" name="disciplina" placeholder="Ex: Cálculo I" required>
            </div>

            <div class="form-group">
                <label>Prioridade</label>
                <select name="prioridade" required>
                    <option value="">Selecione...</option>
                    <option value="Alta">Alta</option>
                    <option value="Média">Média</option>
                    <option value="Baixa">Baixa</option>
                </select>
            </div>

            <div class="form-group">
                <label>Prazo</label>
                <input type="datetime-local" name="prazo" required>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Salvar</button>
                <a href="@Url.Action("Index")" class="btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>

    <style>
        .form-container { max-width: 600px; margin: 30px auto; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
        .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-family: Arial; }
        .form-actions { margin-top: 30px; }
        .btn-primary, .btn-secondary { padding: 10px 20px; margin-right: 10px; text-decoration: none; border-radius: 4px; cursor: pointer; border: none; font-size: 14px; }
        .btn-primary { background-color: #28a745; color: white; }
        .btn-secondary { background-color: #6c757d; color: white; }
    </style>
</body>
</html>
