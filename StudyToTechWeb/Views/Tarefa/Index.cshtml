@using StudyToTechWeb.Models
@model List<Tarefa>

@{
    ViewData["Title"] = "Tarefas";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tarefas</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Tarefas</h1>
            <a href="@Url.Action("Index", "Home")" class="back-link">← Voltar</a>
        </header>

        <div class="actions">
            <a href="@Url.Action("Criar")" class="btn-primary">+ Nova Tarefa</a>
        </div>

        <div class="tarefas-list">
            @if (Model != null && Model.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Disciplina</th>
                            <th>Prioridade</th>
                            <th>Prazo</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tarefa in Model)
                        {
                            <tr>
                                <td>@tarefa.Titulo</td>
                                <td>@tarefa.Disciplina</td>
                                <td><span class="priority-badge priority-@tarefa.Prioridade?.ToLower()">@tarefa.Prioridade</span></td>
                                <td>@tarefa.Prazo.ToString("dd/MM/yyyy")</td>
                                <td>@tarefa.Status</td>
                                <td>
                                    @if (tarefa.Status != "Concluída")
                                    {
                                        <a href="@Url.Action("Completar", new { id = tarefa.Id })" class="btn-sm btn-success">Concluir</a>
                                    }
                                    <a href="@Url.Action("Deletar", new { id = tarefa.Id })" class="btn-sm btn-danger" onclick="return confirm('Tem certeza?')">Deletar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Nenhuma tarefa cadastrada.</p>
            }
        </div>
    </div>

    <style>
        .tarefas-list { margin-top: 20px; }
        .table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .table th, .table td { padding: 10px; border: 1px solid #ddd; text-align: left; }
        .table th { background-color: #007bff; color: white; }
        .priority-badge { padding: 3px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; }
        .priority-alta { background-color: #dc3545; color: white; }
        .priority-média { background-color: #ffc107; color: black; }
        .priority-baixa { background-color: #28a745; color: white; }
        .actions { margin: 20px 0; }
        .btn-primary, .btn-sm { padding: 8px 15px; margin-right: 5px; text-decoration: none; border-radius: 4px; cursor: pointer; }
        .btn-primary { background-color: #28a745; color: white; }
        .btn-success { background-color: #20c997; color: white; }
        .btn-danger { background-color: #dc3545; color: white; }
        .back-link { margin-left: 20px; cursor: pointer; }
    </style>
</body>
</html>
