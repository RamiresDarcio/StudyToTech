@using StudyToTechWeb.Models
@model List<MetaEstudo>

@{
    ViewData["Title"] = "Metas de Estudo";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Metas de Estudo</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Metas de Estudo</h1>
            <a href="@Url.Action("Index", "Home")" class="back-link">← Voltar</a>
        </header>

        <div class="actions">
            <a href="@Url.Action("Criar")" class="btn-primary">+ Nova Meta</a>
        </div>

        <div class="metas-list">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var meta in Model)
                {
                    <div class="meta-card">
                        <h3>@meta.Titulo</h3>
                        <p>@meta.Descricao</p>
                        <div class="progress-bar">
                            <div class="progress" style="width: @(meta.Progresso)%"></div>
                        </div>
                        <p>Progresso: @meta.Progresso% / 100%</p>
                        <small>Prazo: @meta.DataLimite.ToString("dd/MM/yyyy")</small>
                        <div style="margin-top: 10px;">
                            <a href="@Url.Action("AtualizarProgresso", new { id = meta.Id, progresso = 50 })" class="btn-sm btn-info">Atualizar Progresso</a>
                            <a href="@Url.Action("Deletar", new { id = meta.Id })" class="btn-sm btn-danger" onclick="return confirm('Tem certeza?')">Deletar</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>Nenhuma meta cadastrada.</p>
            }
        </div>
    </div>

    <style>
        .metas-list { margin-top: 20px; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .meta-card { border: 1px solid #ddd; border-radius: 8px; padding: 15px; background-color: #f9f9f9; }
        .meta-card h3 { margin-top: 0; }
        .progress-bar { width: 100%; background-color: #e0e0e0; border-radius: 4px; height: 10px; margin: 10px 0; }
        .progress { background-color: #28a745; height: 100%; border-radius: 4px; }
        .actions { margin: 20px 0; }
        .btn-primary, .btn-sm { padding: 8px 15px; margin-right: 5px; text-decoration: none; border-radius: 4px; cursor: pointer; }
        .btn-primary { background-color: #28a745; color: white; }
        .btn-info { background-color: #17a2b8; color: white; }
        .btn-danger { background-color: #dc3545; color: white; }
        .back-link { margin-left: 20px; cursor: pointer; }
    </style>
</body>
</html>
